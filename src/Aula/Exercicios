-- Trigger para INSERT
CREATE TRIGGER trg_salario_positivo_insert
BEFORE INSERT ON Empregados
FOR EACH ROW
WHEN NEW.Salario <= 0
BEGIN
    SELECT RAISE(ABORT, 'O salário deve ser um valor positivo.');
END;

-- Trigger para UPDATE
CREATE TRIGGER trg_salario_positivo_update
BEFORE UPDATE OF Salario ON Empregados
FOR EACH ROW
WHEN NEW.Salario <= 0
BEGIN
    SELECT RAISE(ABORT, 'O salário deve ser um valor positivo.');
END;


-- Trigger para INSERT
CREATE TRIGGER trg_datas_projeto_validas_insert
BEFORE INSERT ON Projetos
FOR EACH ROW
WHEN NEW.DataFim_proj IS NOT NULL AND NEW.DataFim_proj < NEW.DataIni_proj
BEGIN
    SELECT RAISE(ABORT, 'A data de fim do projeto não pode ser anterior à data de início.');
END;

-- Trigger para UPDATE
CREATE TRIGGER trg_datas_projeto_validas_update
BEFORE UPDATE OF DataIni_proj, DataFim_proj ON Projetos
FOR EACH ROW
WHEN NEW.DataFim_proj IS NOT NULL AND NEW.DataFim_proj < NEW.DataIni_proj
BEGIN
    SELECT RAISE(ABORT, 'A data de fim do projeto não pode ser anterior à data de início.');
END;




CREATE VIEW vw_empregados_departamentos AS
SELECT
    e.Id_emp,
    e.Nome,
    e.Sobrenome,
    e.Salario,
    d.Nome_dep,
    d.Regiao_dep
FROM
    Empregados e
JOIN
    Departamentos d ON e.Cod_dep = d.Cod_dep;


CREATE VIEW vw_alocacao_projetos AS
SELECT
    e.Nome || ' ' || e.Sobrenome AS Nome_Empregado,
    p.Descr_proj AS Nome_Projeto,
    p.DataIni_proj AS Inicio_Projeto,
    p.DataFim_proj AS Fim_Projeto
FROM
    Alocacao a
JOIN
    Empregados e ON a.Id_emp = e.Id_emp
JOIN
    Projetos p ON a.Cod_proj = p.Cod_proj;


CREATE VIEW vw_resumo_salarial_departamento AS
SELECT
    d.Nome_dep,
    COUNT(e.Id_emp) AS Total_Empregados,
    SUM(e.Salario) AS Salario_Total,
    AVG(e.Salario) AS Salario_Medio
FROM
    Departamentos d
LEFT JOIN
    Empregados e ON d.Cod_dep = e.Cod_dep
GROUP BY
    d.Nome_dep;


SELECT AVG(e.Salario ) as "Salario Médio", e.Nome 
from Empregados e 
join Departamentos d 
ON e.Cod_dep = d.Cod_dep 
GROUP BY d.Nome_dep 
HAVING "Salario Médio" > 5000
order by "Salario Médio" DESC;


CREATE VIEW budget (NOME, ORCAMEN) AS
SELECT PNOME, ORCAMEN
FROM PROJ
WHERE orcamen = 100000;


CREATE VIEW FuncionarioProjeto AS
SELECT e.Nome, e.Salario, p.Descr_Proj, p.DataIni_Proj
FROM Empregados e
JOIN Alocacao a ON e.Id_Emp = a.Id_Emp
JOIN Projetos p ON a.Cod_Proj = p.Cod_Proj;


CREATE VIEW ProjetosEmpregados AS
SELECT p.Descr_Proj, COUNT(a.Id_Emp) AS numero_funcionarios
FROM Projetos p
LEFT JOIN Alocacao a ON p.Cod_Proj = a.Cod_Proj
GROUP BY p.Cod_Proj;


CREATE VIEW EmpregadosDepartamento AS
SELECT e.Nome, e.Salario,
       (SELECT AVG(Salario) FROM Empregados WHERE Cod_Depto = e.Cod_Depto) AS media_salarial
FROM Empregados e;
