CREATE TABLE Departamentos (
	Cod_dep INTEGER PRIMARY KEY AUTOINCREMENT,
	Nome_dep VARCHAR(100) NOT NULL,
	Regiao_dep VARCHAR(50) NOT NULL
);

CREATE TABLE Empregados (
	Id_emp INTEGER PRIMARY KEY AUTOINCREMENT,
	Nome VARCHAR(100) NOT NULL,
	Sobrenome VARCHAR(100) NOT NULL,
	Salario DECIMAL(10,2) NOT NULL,
	Cod_dep INT,
	FOREIGN KEY (Cod_dep) REFERENCES Departamentos (Cod_dep)
);

CREATE TABLE Projetos (
	Cod_proj INTEGER PRIMARY KEY AUTOINCREMENT,
	Descr_proj VARCHAR(150) NOT NULL,
	DataIni_proj DATE NOT NULL,
	DataFim_proj DATE 
);

CREATE TABLE Alocacao (
	Id_emp INT,
	Cod_proj INT,
	PRIMARY KEY (Id_emp, Cod_proj),
	FOREIGN KEY (Id_emp) REFERENCES Empregados (Id_emp),
	FOREIGN KEY (Cod_proj) REFERENCES Projetos (Cod_proj)
);

