CREATE VIEW Analise_Estrategica_Depto AS
SELECT
    d.Nome_Depto,

    -- 1. Contagem (Agregação Simples)
    COUNT(p.Cod_Proj) AS Qtd_Projetos,

    -- 2. Média (Agregação Simples)
    AVG(e.Salario) AS Media_Salarial_Depto,

    -- 3. Lógica Condicional (CASE WHEN)
    CASE
        WHEN SUM(p.Orcamento) > 1000000 THEN 'Alto Custo'
        ELSE 'Normal'
    END AS Classificacao_Orcamento,

    -- 4. Subquery na Coluna (A parte mais difícil)
    (AVG(e.Salario) - (SELECT AVG(Salario) FROM Empregados)) AS Comparativo_Salarial

FROM Departamentos d
LEFT JOIN Empregados e ON d.Cod_Depto = e.Cod_Depto
LEFT JOIN Projetos p ON d.Cod_Depto = p.Cod_Depto
GROUP BY d.Nome_Depto;



CREATE VIEW Relatorio_Crise_Projetos AS
SELECT
    p.Descr_Proj,

    -- 1. Cálculo de Datas (Exemplo genérico, no SQLite seria julianday) [cite: 680]
    (p.DataFim_Proj - p.DataIni_Proj) AS Duracao_Dias,

    -- 2. Agregação Simples
    COUNT(a.Id_Emp) AS Total_Colaboradores,

    -- 3. Lógica Condicional Complexa
    CASE
        WHEN COUNT(a.Id_Emp) > 5 AND (p.DataFim_Proj - p.DataIni_Proj) < 30 THEN 'Crítico (Superlotado)'
        WHEN COUNT(a.Id_Emp) = 0 THEN 'Fantasma'
        ELSE 'Regular'
    END AS Status_Risco,

    -- 4. Subquery de Cálculo (Total deste proj - Média Geral)
    (COUNT(a.Id_Emp) - (SELECT COUNT(Id_Emp) / COUNT(DISTINCT Cod_Proj) FROM Alocacao)) AS Desvio_Media

FROM Projetos p
LEFT JOIN Alocacao a ON p.Cod_Proj = a.Cod_Proj -- LEFT JOIN para pegar projetos 'Fantasma' (sem alocação) [cite: 666]
GROUP BY p.Descr_Proj, p.DataFim_Proj, p.DataIni_Proj;



CREATE VIEW Performance_Gerentes AS
WITH Resumo_Equipa AS (
    -- CTE para calcular os totais antes de juntar com os nomes [cite: 713-715]
    SELECT
        Id_Supervisor,
        COUNT(*) as Qtd_Subordinados,
        SUM(Salario) as Custo_Total
    FROM Empregados
    WHERE Id_Supervisor IS NOT NULL
    GROUP BY Id_Supervisor
)
SELECT
    e.Nome AS Nome_Gerente,
    r.Qtd_Subordinados,
    r.Custo_Total,
    CASE
        WHEN r.Custo_Total > 50000 THEN 'Auditar'
        ELSE 'OK'
    END AS Alerta_Custo
FROM Empregados e
JOIN Resumo_Equipa r ON e.Id_Emp = r.Id_Supervisor; -- Join do funcionário com o resumo da sua equipe


