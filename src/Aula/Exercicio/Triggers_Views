CREATE VIEW vw_empregados_departamentos AS
SELECT
    e.Id_emp,
    e.Nome,
    e.Sobrenome,
    e.Salario,
    d.Nome_dep,
    d.Regiao_dep
FROM
    Empregados e
JOIN
    Departamentos d ON e.Cod_dep = d.Cod_dep;


CREATE VIEW vw_alocacao_projetos AS
SELECT
    e.Nome || ' ' || e.Sobrenome AS Nome_Empregado,
    p.Descr_proj AS Nome_Projeto,
    p.DataIni_proj AS Inicio_Projeto,
    p.DataFim_proj AS Fim_Projeto
FROM
    Alocacao a
JOIN
    Empregados e ON a.Id_emp = e.Id_emp
JOIN
    Projetos p ON a.Cod_proj = p.Cod_proj;


CREATE VIEW vw_resumo_salarial_departamento AS
SELECT
    d.Nome_dep,
    COUNT(e.Id_emp) AS Total_Empregados,
    SUM(e.Salario) AS Salario_Total,
    AVG(e.Salario) AS Salario_Medio
FROM
    Departamentos d
LEFT JOIN
    Empregados e ON d.Cod_dep = e.Cod_dep
GROUP BY
    d.Nome_dep;


