CREATE TRIGGER trg_auditoria_nome_aqui
AFTER UPDATE OF Coluna_Monitorada ON Tabela_Original
FOR EACH ROW
WHEN OLD.Coluna_Monitorada != NEW.Coluna_Monitorada -- Só grava se mudou
BEGIN
    INSERT INTO Tabela_Historico (
        Id_Referencia, 
        Valor_Antigo, 
        Valor_Novo, 
        Data_Mudanca
    )
    VALUES (
        OLD.Id, 
        OLD.Coluna_Monitorada, 
        NEW.Coluna_Monitorada, 
        DATETIME('now') -- ou CURRENT_TIMESTAMP
    );
END;



CREATE TRIGGER trg_automacao_status
AFTER DELETE ON Tabela_Alocacao
FOR EACH ROW
-- Verifica se a contagem zerou após o delete
WHEN (SELECT COUNT(*) FROM Tabela_Alocacao WHERE Id_Projeto = OLD.Id_Projeto) = 0
BEGIN
    UPDATE Tabela_Projetos
    SET Status = 'Inativo'
    WHERE Id_Projeto = OLD.Id_Projeto;
END;



WITH Calculo_Media AS (
    -- Passo 1: Calcular os dados agregados (médias, contagens)
    SELECT 
        Cod_Depto, 
        AVG(Salario) as Media_Salario
    FROM Empregados
    GROUP BY Cod_Depto
)
-- Passo 2: Cruzar com a tabela principal
SELECT 
    e.Nome, 
    e.Salario, 
    c.Media_Salario
FROM Empregados e
JOIN Calculo_Media c ON e.Cod_Depto = c.Cod_Depto
WHERE e.Salario > c.Media_Salario;



CREATE TRIGGER trg_corrige_salario
BEFORE UPDATE OF salario ON funcionario -- Tem que ser BEFORE
FOR EACH ROW
BEGIN
    IF NEW.salario < 2000 THEN
        NEW.salario := NEW.salario * 1.10; -- Usa-se NEW.coluna
    ELSE
        NEW.salario := NEW.salario * 1.05;
    END IF;
END;



